{
  "name": "acervo-digital-backend",
  "version": "1.0.0",
  "description": "Backend API para o Acervo Digital de ODAs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name auto",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/prisma/seed.ts",
    "db:query": "node query-db.js",
    "db:reset-views": "tsx src/scripts/reset-views.ts",
    "db:setup": "prisma db push && prisma generate",
    "db:fix-lock": "powershell -ExecutionPolicy Bypass -File fix-db-lock.ps1",
    "db:generate-only": "powershell -ExecutionPolicy Bypass -File generate-client.ps1",
    "db:fix-client": "powershell -ExecutionPolicy Bypass -File fix-prisma-client.ps1"
  },
  "keywords": ["oda", "acervo", "educacao"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "prisma": "^5.7.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}

